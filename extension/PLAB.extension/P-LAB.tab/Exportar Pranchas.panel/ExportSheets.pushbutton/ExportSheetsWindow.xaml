<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExportSheets P-LAB v2.3.0" 
        Width="900" Height="700" 
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="24"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="20,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- CABECALHO -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          Text="ExportSheets P-LAB"
                          Foreground="White"
                          FontSize="20"
                          FontWeight="Bold"
                          VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" 
                          Text="Exportacao Profissional de Pranchas"
                          Foreground="#BDC3C7"
                          FontSize="11"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="20,0"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="save_profile_btn"
                           Content="Salvar Perfil"
                           Background="#3498DB"
                           Foreground="White"
                           Padding="12,4"
                           Margin="0,0,5,0"/>
                    
                    <Button x:Name="load_profile_btn"
                           Content="Carregar Perfil"
                           Background="#9B59B6"
                           Foreground="White"
                           Padding="12,4"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- CONTEUDO PRINCIPAL -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- COLUNA ESQUERDA -->
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    
                    <!-- FORMATOS -->
                    <GroupBox Header="Formatos de Exportacao">
                        <StackPanel>
                            <CheckBox x:Name="export_pdf_cb" 
                                     Content="Exportar PDF"
                                     IsChecked="True"
                                     FontWeight="Bold"/>
                            
                            <CheckBox x:Name="export_dwg_cb" 
                                     Content="Exportar DWG"
                                     FontWeight="Bold"/>
                            
                            <CheckBox x:Name="export_dwf_cb" 
                                     Content="Exportar DWF"
                                     FontWeight="Bold"/>
                            
                            <Separator Margin="5,8"/>
                            
                            <CheckBox x:Name="create_subfolders_cb" 
                                     Content="Criar subpastas para cada tipo (PDF/DWG/DWF)"
                                     IsChecked="True"
                                     Margin="5,5,5,2"/>
                            
                            <Separator Margin="5,8"/>
                            
                            <CheckBox x:Name="combine_pdf_cb" 
                                     Content="Combinar em um unico PDF"/>
                            
                            <Grid Margin="20,3,5,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                          Text="Nome:"
                                          VerticalAlignment="Center"
                                          Margin="0,0,5,0"/>
                                
                                <TextBox Grid.Column="1" 
                                        x:Name="combined_name_tb"
                                        Text="Conjunto_Pranchas"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- NOMENCLATURA -->
                    <GroupBox Header="Nomenclatura dos Arquivos">
                        <StackPanel>

                            <!-- PREFIXO / SUFIXO -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                          Text="Prefixo:" 
                                          VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" 
                                        x:Name="prefix_tb"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                          Text="Sufixo:" 
                                          VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" 
                                        x:Name="suffix_tb"/>
                            </Grid>

                            <!-- SEPARADOR -->
                            <Grid Margin="5,6,5,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="Separador:"
                                          VerticalAlignment="Center"
                                          FontSize="11"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton x:Name="sep_hifen_rb"
                                                Content="Hífen  ( - )"
                                                GroupName="separador"
                                                IsChecked="True"
                                                Margin="0,0,10,0"/>
                                    <RadioButton x:Name="sep_underline_rb"
                                                Content="Underline  ( _ )"
                                                GroupName="separador"
                                                Margin="0,0,10,0"/>
                                    <RadioButton x:Name="sep_ponto_rb"
                                                Content="Ponto  ( . )"
                                                GroupName="separador"/>
                                </StackPanel>
                            </Grid>

                            <Separator Margin="5,6"/>

                            <!-- CHECKBOXES NUMERO / NOME -->
                            <Grid Margin="5,2,5,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox Grid.Column="0" 
                                         x:Name="include_number_cb"
                                         Content="Incluir Numero"
                                         IsChecked="True"/>
                                
                                <CheckBox Grid.Column="1" 
                                         x:Name="include_name_cb"
                                         Content="Incluir Nome"
                                         IsChecked="True"/>
                            </Grid>

                            <!-- BOTAO MONTAR NOME -->
                            <Border Margin="5,2,5,5"
                                   Padding="8"
                                   Background="#E3F2FD"
                                   BorderBrush="#2196F3"
                                   BorderThickness="1"
                                   CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Composicao personalizada do nome:"
                                                  FontWeight="Bold"
                                                  FontSize="10"
                                                  Foreground="#1565C0"/>
                                        <TextBlock x:Name="nome_formula_tb"
                                                  Text="(usando Numero + Nome padrao)"
                                                  FontFamily="Consolas"
                                                  FontSize="10"
                                                  Foreground="#1976D2"
                                                  TextWrapping="Wrap"
                                                  Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                           x:Name="build_name_btn"
                                           Content="Montar Nome"
                                           Background="#1976D2"
                                           Foreground="White"
                                           FontSize="10"
                                           Padding="10,4"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            
                            <!-- PREVIEW -->
                            <Border Background="#E8F5E9" 
                                   Padding="8" 
                                   Margin="5"
                                   BorderBrush="#4CAF50"
                                   BorderThickness="1"
                                   CornerRadius="2">
                                <StackPanel>
                                    <TextBlock Text="Preview:" 
                                              FontWeight="Bold"
                                              FontSize="10"
                                              Foreground="#2E7D32"/>
                                    <TextBlock x:Name="preview_tb" 
                                              Text="01-PLANTA BAIXA.pdf"
                                              FontFamily="Consolas"
                                              FontSize="11"
                                              Foreground="#1B5E20"
                                              Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- POSICAO DO PAPEL -->
                    <GroupBox Header="Colocacao de Papel">
                        <StackPanel>
                            <RadioButton x:Name="position_center_rb"
                                        Content="Centro"
                                        GroupName="position"
                                        IsChecked="True"/>
                            
                            <RadioButton x:Name="position_offset_rb"
                                        Content="Deslocamento do canto"
                                        GroupName="position"/>
                            
                            <ComboBox x:Name="margins_cb"
                                     Margin="25,3,5,5"
                                     IsEnabled="False"
                                     Height="22">
                                <ComboBoxItem Content="Sem margem" Tag="none" IsSelected="True"/>
                                <ComboBoxItem Content="Definida pelo usuario" Tag="custom"/>
                            </ComboBox>
                            
                            <Border x:Name="custom_margins_border"
                                   Margin="25,3,5,5"
                                   Padding="8"
                                   Background="#FFF9C4"
                                   BorderBrush="#FBC02D"
                                   BorderThickness="1"
                                   CornerRadius="2"
                                   Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="25"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                              Text="X:" 
                                              VerticalAlignment="Center"
                                              FontSize="10"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                            x:Name="margin_x_tb"
                                            Text="0.0000"
                                            Height="22"
                                            Margin="2"/>
                                    
                                    <TextBlock Grid.Row="0" Grid.Column="2" 
                                              Text="Y:" 
                                              VerticalAlignment="Center"
                                              FontSize="10"
                                              Margin="5,0,0,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="3" 
                                            x:Name="margin_y_tb"
                                            Text="0.0000"
                                            Height="22"
                                            Margin="2"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                                              Text="Valores em mm"
                                              FontSize="9"
                                              Foreground="#757575"
                                              HorizontalAlignment="Right"
                                              Margin="0,2,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                    
                </StackPanel>
                
                <!-- COLUNA DIREITA -->
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    
                    <!-- OPCOES DE PDF -->
                    <GroupBox Header="Opcoes de PDF">
                        <StackPanel>
                            <TextBlock Text="Zoom:" 
                                      FontWeight="Bold" 
                                      Margin="5,2,5,2"/>
                            
                            <RadioButton x:Name="zoom_fit_rb" 
                                        Content="Fit to Page (Ajustar a pagina)"
                                        GroupName="zoom"
                                        IsChecked="True"/>
                            
                            <RadioButton x:Name="zoom_100_rb" 
                                        Content="Zoom 100%"
                                        GroupName="zoom"/>
                            
                            <Separator Margin="5,8"/>
                            
                            <TextBlock Text="Processamento:" 
                                      FontWeight="Bold" 
                                      Margin="5,2,5,2"/>
                            
                            <RadioButton x:Name="vector_rb" 
                                        Content="Vector Processing (Recomendado)"
                                        GroupName="processing"
                                        IsChecked="True"/>
                            
                            <RadioButton x:Name="raster_rb" 
                                        Content="Raster Processing"
                                        GroupName="processing"/>
                            
                            <!-- Opcoes Vector -->
                            <Border x:Name="vector_options_border"
                                   Margin="25,3,5,5"
                                   Padding="8"
                                   Background="#E3F2FD"
                                   BorderBrush="#2196F3"
                                   BorderThickness="1"
                                   CornerRadius="2">
                                <StackPanel>
                                    <TextBlock Text="Qualidade:" 
                                              FontWeight="Bold"
                                              FontSize="10"
                                              Margin="0,0,0,3"/>
                                    
                                    <ComboBox x:Name="vector_quality_cb" Height="22">
                                        <ComboBoxItem Content="Baixa" Tag="low"/>
                                        <ComboBoxItem Content="Media" Tag="medium"/>
                                        <ComboBoxItem Content="Alta" Tag="high" IsSelected="True"/>
                                        <ComboBoxItem Content="Apresentacao" Tag="presentation"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            
                            <!-- Opcoes Raster -->
                            <Border x:Name="raster_options_border"
                                   Margin="25,3,5,5"
                                   Padding="8"
                                   Background="#FFF3E0"
                                   BorderBrush="#FF9800"
                                   BorderThickness="1"
                                   CornerRadius="2"
                                   Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Qualidade:" 
                                              FontWeight="Bold"
                                              FontSize="10"
                                              Margin="0,0,0,3"/>
                                    
                                    <ComboBox x:Name="raster_quality_cb" Height="22">
                                        <ComboBoxItem Content="Baixa (72 DPI)" Tag="low"/>
                                        <ComboBoxItem Content="Media (150 DPI)" Tag="medium"/>
                                        <ComboBoxItem Content="Alta (300 DPI)" Tag="high" IsSelected="True"/>
                                        <ComboBoxItem Content="Apresentacao (600 DPI)" Tag="presentation"/>
                                    </ComboBox>
                                    
                                    <TextBlock Text="Cores:" 
                                              FontWeight="Bold"
                                              FontSize="10"
                                              Margin="0,8,0,3"/>
                                    
                                    <ComboBox x:Name="raster_colors_cb" Height="22">
                                        <ComboBoxItem Content="Colorido" Tag="color" IsSelected="True"/>
                                        <ComboBoxItem Content="Escala de Cinza" Tag="grayscale"/>
                                        <ComboBoxItem Content="Preto e Branco" Tag="blackline"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                            
                            <Separator Margin="5,8"/>
                            
                            <TextBlock Text="Visibilidade:" 
                                      FontWeight="Bold" 
                                      Margin="5,2,5,2"/>
                            
                            <CheckBox x:Name="hide_ref_cb"
                                     Content="Ocultar Planos de Referencia"
                                     IsChecked="True"/>
                            
                            <CheckBox x:Name="hide_scope_cb"
                                     Content="Ocultar Scope Boxes"
                                     IsChecked="True"/>
                            
                            <CheckBox x:Name="hide_crop_cb"
                                     Content="Ocultar Crop Boundaries"
                                     IsChecked="True"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- CONFIGURACAO DWG -->
                    <GroupBox Header="Configuracao DWG">
                        <StackPanel>
                            <TextBlock Text="Configuracao:" 
                                      FontWeight="Bold" 
                                      Margin="5,2,5,3"/>
                            
                            <ComboBox x:Name="dwg_setup_cb" Height="22"/>

                            <Separator Margin="5,8"/>

                            <!-- VINCULAR IMAGENS -->
                            <CheckBox x:Name="bind_images_cb"
                                     Content="Vincular imagens ao DWG"
                                     IsChecked="False"
                                     FontWeight="Bold"/>

                            <!-- Painel de info - visivel quando marcado -->
                            <Border x:Name="bind_images_info_border"
                                   Margin="5,4,5,2"
                                   Padding="8"
                                   Background="#E8F5E9"
                                   BorderBrush="#4CAF50"
                                   BorderThickness="1"
                                   CornerRadius="2"
                                   Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap"
                                              FontSize="10"
                                              Foreground="#1B5E20">
                                        <Run FontWeight="Bold" Text="Como funciona:"/>
                                        <Run Text=" As imagens (logos, carimbos) sao embutidas diretamente dentro do DWG como objetos OLE — o arquivo final e completamente independente, sem necessidade de enviar imagens separadas ao cliente."/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0"
                                              TextWrapping="Wrap"
                                              FontSize="10"
                                              Foreground="#2E7D32">
                                        <Run FontWeight="Bold" Text="Processo:"/>
                                        <Run Text=" O AutoCAD e aberto em segundo plano para processar cada DWG. Dependendo da quantidade de pranchas, esta etapa pode demorar alguns minutos a mais."/>
                                    </TextBlock>
                                    <TextBlock Margin="0,5,0,0"
                                              TextWrapping="Wrap"
                                              FontSize="10"
                                              Foreground="#1565C0">
                                        <Run FontWeight="Bold" Text="Requisito:"/>
                                        <Run Text=" AutoCAD 2017+ instalado (nao funciona com AutoCAD LT)."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Painel de aviso - visivel quando NAO marcado -->
                            <Border x:Name="bind_images_tip_border"
                                   Margin="5,4,5,2"
                                   Padding="8"
                                   Background="#FFF9C4"
                                   BorderBrush="#FBC02D"
                                   BorderThickness="1"
                                   CornerRadius="2"
                                   Visibility="Visible">
                                <TextBlock TextWrapping="Wrap"
                                          FontSize="10"
                                          Foreground="#5D4037">
                                    <Run FontWeight="Bold" Text="Dica:"/>
                                    <Run Text=" Ative esta opcao para que logos e imagens dos carimbos sejam incluidas ao enviar o DWG para o cliente."/>
                                </TextBlock>
                            </Border>

                        </StackPanel>
                    </GroupBox>
                    
                </StackPanel>
                
            </Grid>
        </ScrollViewer>
        
        <!-- BOTOES -->
        <Border Grid.Row="2" 
               Background="White" 
               BorderBrush="#BDBDBD" 
               BorderThickness="0,1,0,0"
               Padding="10">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Right">
                <Button x:Name="export_btn" 
                       Content="Exportar" 
                       Background="#4CAF50"
                       Foreground="White"
                       FontWeight="Bold"
                       Width="130"/>
                
                <Button x:Name="cancel_btn" 
                       Content="Cancelar"
                       Width="130"/>
            </StackPanel>
        </Border>
        
        <!-- RODAPE -->
        <Border Grid.Row="3" Background="#34495E" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                    <Run Text="P-LAB Engenharia" 
                         Foreground="White" 
                         FontWeight="Bold" 
                         FontSize="10"/>
                </TextBlock>
                
                <TextBlock Grid.Column="1" 
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                    <Run Text="(61) 98206-8746" 
                         Foreground="#BDC3C7" 
                         FontSize="9"/>
                    <Run Text=" | " 
                         Foreground="#7F8C8D" 
                         FontSize="9"/>
                    <Run Text="engpicanco@yahoo.com.br" 
                         Foreground="#BDC3C7" 
                         FontSize="9"/>
                </TextBlock>
                
                <TextBlock Grid.Column="2" 
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center">
                    <Run Text="v2.3.0" 
                         Foreground="#95A5A6" 
                         FontSize="9" 
                         FontWeight="Bold"/>
                </TextBlock>
            </Grid>
        </Border>
        
    </Grid>
</Window>